              "})",
              "",
              "// Test 2 — Vérifier que l'email contient @",
              "pm.test(\"Email est valide\", function() {",
              "    const donnees = pm.response.json()",
              "    pm.expect(donnees.email).to.include(\"@\")",
              "})",
              "",
              "// Test 3 — Vérifier que le nom n'est pas vide",
              "pm.test(\"Nom n'est pas vide\", function() {",
              "    const donnees = pm.response.json()",
              "    pm.expect(donnees.name).to.not.be.empty",
              "})"
